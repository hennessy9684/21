# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,your-server-ip

# Database Settings (MySQL)
USE_MYSQL=True
MYSQL_DATABASE=day21
MYSQL_USER=day21_user
MYSQL_PASSWORD=your-mysql-password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# CORS Settings
CORS_ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://your-domain.com,https://your-domain.com
