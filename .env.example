# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,your-server-ip

# Database Settings (MySQL)
USE_MYSQL=True
MYSQL_DATABASE=day21
MYSQL_USER=day21_user
MYSQL_PASSWORD=your-mysql-password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# CORS Settings
CORS_ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://your-domain.com,https://your-domain.com

# 阿里云短信认证配置（个人开发者可用，无需企业资质）
# 1. 阿里云账号完成个人实名认证
# 2. 开通号码认证服务：https://dypns.console.aliyun.com/functions
# 3. 获取赠送签名：https://dypns.console.aliyun.com/smsCertParamsConfig/sign
# 4. 获取赠送模板：https://dypns.console.aliyun.com/smsCertParamsConfig/template
# 5. 创建 AccessKey：https://ram.console.aliyun.com/users
SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
SMS_SIGN_NAME=平台赠送的签名名称
SMS_TEMPLATE_CODE=平台赠送的模板CODE
